# Ship Tracker Intelligence Platform — Streamlit Secrets
# Copy this file to .streamlit/secrets.toml and fill in your API keys
# On Streamlit Cloud: add these in App Settings → Secrets

# ── NewsAPI (https://newsapi.org — free tier: 100 req/day) ──────────────────
NEWS_API_KEY = "your_newsapi_key_here"

# ── Alpha Vantage (https://alphavantage.co — free tier: 25 req/day) ─────────
ALPHA_VANTAGE_KEY = "your_alpha_vantage_key_here"

# ── FRED (https://fred.stlouisfed.org/docs/api — free) ──────────────────────
FRED_API_KEY = "your_fred_api_key_here"
